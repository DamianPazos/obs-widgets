{
  "name": "@obs-widgets/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "App de escritorio (Electron) que corre junto con OBS: levanta el server de eventos y sirve todos los widgets en localhost.",
  "main": "dist/main.js",
  "scripts": {
    "dev": "pnpm --filter @obs-widgets/widgets build && tsup && node scripts/launch-electron.mjs",
    "start": "node scripts/launch-electron.mjs",
    "build": "tsup",
    "start:headless": "node dist/headless.js",
    "package": "pnpm --filter @obs-widgets/widgets build && tsup && electron-builder",
    "release": "pnpm --filter @obs-widgets/widgets build && tsup && electron-builder --publish always",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@obs-widgets/kick": "workspace:*",
    "@obs-widgets/server": "workspace:*",
    "@obs-widgets/widgets": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-updater": "^6.3.9",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
