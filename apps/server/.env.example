# ---------------------------------------------------------------------------
# Configuración del servidor de eventos (apps/server)
# Copiá este archivo a `apps/server/.env` y completá los valores.
# ---------------------------------------------------------------------------

# Puerto HTTP/WebSocket del servidor relay
PORT=8787

# Origen permitido para CORS / WebSocket (el dev server de widgets)
# Usá "*" solo en desarrollo.
CORS_ORIGIN=http://localhost:5173

# Fuente de eventos: "mock" (sin credenciales, ideal para probar) o "kick"
EVENT_SOURCE=mock

# Habilita el endpoint POST /debug/emit para disparar eventos de prueba.
# Dejar en "false" en producción.
ENABLE_DEBUG_ENDPOINT=true

# ---------------------------------------------------------------------------
# Integración con Kick (solo si EVENT_SOURCE=kick)
# Creá una app en https://kick.com/settings/developer para obtener las credenciales.
#
# Con CLIENT_ID + CLIENT_SECRET + KICK_CHANNEL, el server automáticamente:
#   1. obtiene un app token, 2. resuelve el id del canal,
#   3. se suscribe a los eventos (follows y subs) por webhook,
#   4. descarga la clave pública para verificar firmas.
# Solo tenés que configurar en el panel de Kick el "webhook URL" apuntando a
#   <PUBLIC_URL>/webhooks/kick  y habilitar los webhooks.
# ---------------------------------------------------------------------------

KICK_CLIENT_ID=
KICK_CLIENT_SECRET=

# Slug del canal de Kick que querés monitorear (ej: "xqc")
KICK_CHANNEL=demo

# URL pública del servidor a la que Kick enviará los webhooks.
# En local exponé el server con un túnel (ngrok, cloudflared, etc.) y configurá
# <PUBLIC_URL>/webhooks/kick como webhook URL en el panel de Kick.
# Ej: https://tu-tunel.ngrok-free.app
PUBLIC_URL=

# Verificación de firma de los webhooks de Kick.
# Dejar "true" en producción. Poné "false" solo para pruebas locales sin firma.
KICK_VERIFY_SIGNATURE=true

# Clave pública (PEM) de Kick. Opcional: si hay credenciales, se descarga sola.
# KICK_WEBHOOK_PUBLIC_KEY=
