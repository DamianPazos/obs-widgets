{
  "name": "@obs-widgets/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Servidor relay: recibe eventos de la fuente configurada (mock/Kick) y los reenvía a los widgets por WebSocket.",
  "main": "dist/index.js",
  "exports": {
    ".": "./src/bootstrap.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/static": "^8.0.3",
    "@fastify/websocket": "^11.0.1",
    "@obs-widgets/core": "workspace:*",
    "@obs-widgets/kick": "workspace:*",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
